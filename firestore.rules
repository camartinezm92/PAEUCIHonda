rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: pae_records
    // Document ID: UUID
    // Fields:
    //   - id: string
    //   - date: string (ISO 8601)
    //   - status: string ('INICIADA' or 'CERRADA')
    //   - patient: map (name, id, age, sex, service, medicalDiagnosis)
    //   - needs: list of strings
    //   - otherNeed: string (optional)
    //   - nandas: list of minified objects
    //   - evaluator: string
    //   - observations: string
    //   - userId: string (owner UID)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == 'camartinezm92@gmail.com' ||
        request.auth.token.email.lower() == 'ingbiomedico@ucihonda.com.co' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
         get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'admin')
      );
    }

    function isNurse() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
        get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'nurse';
    }

    function isOwner() {
      return isAuthenticated() && 
             resource != null && 
             'userId' in resource.data && 
             request.auth.uid == resource.data.userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !resource || !('userId' in resource.data) || !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function isValidPAERecord() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'date', 'status', 'patient', 'needs', 'nandas', 'evaluator', 'userId']) &&
             data.status in ['INICIADA', 'CERRADA'] &&
             data.patient is map &&
             data.patient.keys().hasAll(['name', 'id', 'service', 'medicalDiagnosis']) &&
             data.patient.name is string && data.patient.name.size() < 100 &&
             data.patient.id is string && data.patient.id.size() < 50 &&
             data.needs is list && data.needs.size() <= 20 &&
             data.nandas is list && data.nandas.size() <= 50 &&
             data.evaluator is string && data.evaluator.size() < 100 &&
             (!('observations' in data) || (data.observations is string && data.observations.size() < 2000)) &&
             (!('otherNeed' in data) || (data.otherNeed is string && data.otherNeed.size() < 200));
    }

    match /pae_records/{recordId} {
      allow read: if isOwner() || isNurse() || isAdmin();
      allow create: if isAuthenticated() && isDocOwner() && isValidPAERecord();
      allow update: if (isOwner() || isNurse() || isAdmin()) && uidNotModified() && isValidPAERecord();
      allow delete: if isOwner() || isAdmin();
    }

    match /app_settings/{settingId} {
      // Allow anyone to read settings (like the dictionary) to avoid boot errors
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userEmail} {
      // Allow listing users if authenticated (to avoid permission errors in UserManagement)
      // But specific 'get' still requires being the user or an admin
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (request.auth.token.email.lower() == userEmail.lower() || isAdmin());
      
      // Allow creating your own profile
      // If not a master admin, the role MUST be 'viewer'
      allow create: if isAuthenticated() && 
                    request.auth.token.email.lower() == userEmail.lower() &&
                    (request.resource.data.role == 'viewer' || 
                     request.auth.token.email.lower() == 'camartinezm92@gmail.com' ||
                     request.auth.token.email.lower() == 'ingbiomedico@ucihonda.com.co');
      
      // Allow updates if you are an admin OR (it's your own profile AND you don't change your role)
      allow update: if isAuthenticated() && (isAdmin() || (request.auth.token.email.lower() == userEmail.lower() && request.resource.data.role == resource.data.role));
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
  }
}
